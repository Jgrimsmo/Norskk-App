rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function employeeRole() {
      return lower(
        firestore.get(
          /databases/(default)/documents/employees/$(request.auth.uid)
        ).data.role
      );
    }

    function isOpsManager() {
      return isSignedIn() && employeeRole() in ["admin", "pm", "foreman"];
    }

    function isReportAuthor(reportId) {
      return isSignedIn()
        && firestore.get(
          /databases/(default)/documents/dailyReports/$(reportId)
        ).data.authorId == request.auth.uid;
    }

    function isImageUnder10Mb() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /daily-reports/{reportId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isImageUnder10Mb() && (isOpsManager() || isReportAuthor(reportId));
    }

    // Invoice PDF uploads (any file under 20 MB)
    match /invoices/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource != null
        && request.resource.size < 20 * 1024 * 1024
        && isOpsManager();
    }

    // Safety form signatures (images under 5 MB)
    match /safety/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Employee certificate PDFs (up to 10 MB)
    match /employee-certificates/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && isOpsManager();
    }

    // Equipment document PDFs (up to 20 MB)
    match /equipment-documents/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource != null
        && request.resource.size < 20 * 1024 * 1024
        && isOpsManager();
    }

    // Project drawing PDFs (up to 50 MB)
    match /project-drawings/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource != null
        && request.resource.size < 50 * 1024 * 1024
        && isOpsManager();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
